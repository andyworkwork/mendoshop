{
  "name": "mendoshop",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\" && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "icons": "node scripts/generate-icons.mjs",
    "hero-bg": "node scripts/prepare-hero-bg.mjs",
    "import-carrusel": "node scripts/import-carrusel.mjs",
    "carousel:normalize": "node scripts/upscale-hero-carousel.mjs",
    "carousel:sync-slides": "node scripts/sync-hero-carousel-slides.mjs",
    "templates:sync": "node scripts/sync-templates-from-carrusel.mjs",
    "carousel:slide": "node scripts/regenerate-carousel-slide.mjs",
    "configure:auth": "node --env-file=.env.local scripts/configure-supabase-auth-domain.mjs",
    "configure:auth-emails-es": "node --env-file=.env.local scripts/configure-supabase-email-templates-es.mjs",
    "configure:auth-security": "node --env-file=.env.local scripts/configure-supabase-auth-security.mjs",
    "marketing:seed-logo": "node --env-file=.env.local scripts/seed-marketing-logo-asset.mjs"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.0",
    "html2canvas-pro": "^2.0.4",
    "next": "16.2.6",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
